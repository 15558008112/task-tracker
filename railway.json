{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS_PYTHON",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "pip install -r requirements.txt && gunicorn -w 2 -b 0.0.0.0:$PORT app:app"
  }
}
